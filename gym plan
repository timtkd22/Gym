  </div>
</div>

<div class="divider"></div>
<div class="principles">
  <div class="principles-title">Training Principles</div>
  <div class="principles-grid">
    <div class="principle"><strong>Your commute counts</strong> 5km of walking daily is genuine low-intensity aerobic work — part of your recovery capacity.</div>
    <div class="principle"><strong>Desk job antidote</strong> Face pulls and chest-supported rows counteract forward shoulders and hip flexor tightening from 8 hours sitting.</div>
    <div class="principle"><strong>Progressive overload</strong> Every week adds something: volume, weight, intensity, or complexity. Never all at once.</div>
    <div class="principle"><strong>Run pace discipline</strong> 80% of running should feel embarrassingly easy. Most people run easy days too fast.</div>
    <div class="principle"><strong>Protein target</strong> Aim for ~1.8g/kg bodyweight daily. Without it, strength adaptation stalls.</div>
    <div class="principle"><strong>Sleep over everything</strong> 7–9 hours. More valuable than any supplement or extra session.</div>
  </div>
</div>
</div><!-- /view-plan -->

<!-- ==================== TRACKER VIEW ==================== -->
<div class="main-view" id="view-tracker">
  <div class="tracker-header">
    <h2>My Sessions</h2>
    <p>Your logged training across all 4 weeks.</p>
  </div>
  <div class="progress-bar-wrap">
    <div class="progress-label"><span>Overall progress</span><span id="progress-text">0 / 28 sessions</span></div>
    <div class="progress-bg"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
  </div>
  <div id="tracker-body"></div>
</div>

<!-- LOG MODAL -->
<div class="modal-overlay" id="modal" onclick="handleOverlayClick(event)">
  <div class="modal">
    <div class="modal-title" id="modal-title"></div>
    <div class="modal-sub" id="modal-sub"></div>
    <div id="modal-body"></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" onclick="saveLog()">Save session</button>
    </div>
  </div>
</div>

<script>
// ── Storage: use localStorage ────────────────────────────────────
const STORE_KEY = 'reconditioning-log-v1';

function loadAll() {
  try { return JSON.parse(localStorage.getItem(STORE_KEY) || '{}'); }
  catch(e) { return {}; }
}
function saveAll(data) {
  try { localStorage.setItem(STORE_KEY, JSON.stringify(data)); }
  catch(e) { console.error('Save failed', e); }
}

// ── State ────────────────────────────────────────────────────────
var allLogs = loadAll();
var currentSession = null;

// ── Plan nav ─────────────────────────────────────────────────────
function toggleDay(header) {
  header.parentElement.classList.toggle('open');
}

document.querySelectorAll('.tl-week').forEach(function(tab) {
  tab.addEventListener('click', function() {
    var wk = this.dataset.week;
    document.querySelectorAll('.tl-week').forEach(function(t){ t.classList.remove('active'); });
    document.querySelectorAll('.week-panel').forEach(function(p){ p.classList.remove('active'); });
    this.classList.add('active');
    document.getElementById('week-' + wk).classList.add('active');
    window.scrollTo({top:0, behavior:'smooth'});
  });
});

document.querySelectorAll('.nav-tab').forEach(function(tab) {
  tab.addEventListener('click', function() {
    var view = this.dataset.view;
    document.querySelectorAll('.nav-tab').forEach(function(t){ t.classList.remove('active'); });
    document.querySelectorAll('.main-view').forEach(function(v){ v.classList.remove('active'); });
    this.classList.add('active');
    document.getElementById('view-' + view).classList.add('active');
    if (view === 'tracker') renderTracker();
    window.scrollTo({top:0, behavior:'smooth'});
  });
});

// ── Modal ────────────────────────────────────────────────────────
function openLog(id, fullLabel, category, exercises) {
  currentSession = { id: id, fullLabel: fullLabel, category: category, exercises: exercises };
  document.getElementById('modal-title').textContent = fullLabel;
  document.getElementById('modal-sub').textContent = new Date().toLocaleDateString('en-GB', {weekday:'long', day:'numeric', month:'long'});

  var existing = allLogs[id] || null;
  var html = '';
  var isRun = exercises.indexOf('run') !== -1;
  var hasExercises = exercises.length > 0 && !isRun;

  if (isRun) {
    var d = existing || {};
    html += '<div class="modal-section">' +
      '<div class="modal-section-title">Run Data</div>' +
      '<div class="run-fields">' +
        '<div class="field"><label>Distance (km)</label><input type="number" id="r-dist" step="0.1" min="0" placeholder="e.g. 4.2" value="' + (d.dist||'') + '"></div>' +
        '<div class="field"><label>Time (min)</label><input type="number" id="r-time" step="1" min="0" placeholder="e.g. 28" value="' + (d.time||'') + '"></div>' +
        '<div class="field"><label>Avg pace (min/km)</label><input type="text" id="r-pace" placeholder="e.g. 6:30" value="' + (d.pace||'') + '"></div>' +
        '<div class="field"><label>Avg HR (bpm)</label><input type="number" id="r-hr" step="1" min="0" placeholder="optional" value="' + (d.hr||'') + '"></div>' +
      '</div></div>';
  }

  if (hasExercises) {
    html += '<div class="modal-section"><div class="modal-section-title">Sets · Reps · Weight (kg)</div>';
    exercises.forEach(function(ex) {
      var exData = (existing && existing.exercises && existing.exercises[ex]) || [{},{},{},{}];
      var safeEx = ex.replace(/'/g, "\\'");
      html += '<div class="strength-exercise"><div class="strength-ex-name">' + ex + '</div><div class="set-rows">';
      for (var s = 0; s < 4; s++) {
        var sd = exData[s] || {};
        html += '<div class="set-row">' +
          '<span class="set-label">Set ' + (s+1) + '</span>' +
          '<input class="set-input" type="number" min="0" step="1" placeholder="reps" value="' + (sd.reps||'') + '" data-ex="' + safeEx + '" data-s="' + s + '" data-f="reps">' +
          '<input class="set-input" type="number" min="0" step="0.5" placeholder="kg" value="' + (sd.kg||'') + '" data-ex="' + safeEx + '" data-s="' + s + '" data-f="kg">' +
          '</div>';
      }
      html += '</div></div>';
    });
    html += '</div>';
  }

  html += '<div class="modal-section">' +
    '<div class="modal-section-title">Notes (optional)</div>' +
    '<textarea id="r-notes" placeholder="How did it feel? Any aches, PBs, adjustments...">' + ((existing && existing.notes) || '') + '</textarea>' +
    '</div>';

  document.getElementById('modal-body').innerHTML = html;
  document.getElementById('modal').classList.add('open');
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  currentSession = null;
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('modal')) closeModal();
}

function saveLog() {
  if (!currentSession) return;
  var id = currentSession.id;
  var exercises = currentSession.exercises;
  var isRun = exercises.indexOf('run') !== -1;
  var hasExercises = exercises.length > 0 && !isRun;

  var entry = { category: currentSession.category, savedAt: new Date().toISOString() };

  if (isRun) {
    var distEl = document.getElementById('r-dist');
    var timeEl = document.getElementById('r-time');
    var paceEl = document.getElementById('r-pace');
    var hrEl   = document.getElementById('r-hr');
    entry.dist = distEl ? distEl.value : '';
    entry.time = timeEl ? timeEl.value : '';
    entry.pace = paceEl ? paceEl.value : '';
    entry.hr   = hrEl   ? hrEl.value   : '';
  }

  if (hasExercises) {
    entry.exercises = {};
    exercises.forEach(function(ex) {
      entry.exercises[ex] = [];
      for (var s = 0; s < 4; s++) {
        var repsEl = document.querySelector('[data-ex="' + ex + '"][data-s="' + s + '"][data-f="reps"]');
        var kgEl   = document.querySelector('[data-ex="' + ex + '"][data-s="' + s + '"][data-f="kg"]');
        entry.exercises[ex].push({
          reps: repsEl ? repsEl.value : '',
          kg:   kgEl   ? kgEl.value   : ''
        });
      }
    });
  }

  var notesEl = document.getElementById('r-notes');
  entry.notes = notesEl ? notesEl.value : '';

  allLogs[id] = entry;
  saveAll(allLogs);

  var card = document.getElementById('card-' + id);
  if (card) card.classList.add('logged');

  closeModal();
  updateProgress();
}

// ── Tracker ──────────────────────────────────────────────────────
var WEEKS = [
  { label:'Week 1 — Reawaken', days:[
    {id:'w1-mon', name:'Monday — Easy Run + Activation', type:'run'},
    {id:'w1-tue', name:'Tuesday — Full Body Strength A', type:'strength'},
    {id:'w1-wed', name:'Wednesday — Active Recovery + Mobility', type:'mobility'},
    {id:'w1-thu', name:'Thursday — Full Body Strength B', type:'strength'},
    {id:'w1-fri', name:'Friday — Easy Run', type:'run'},
    {id:'w1-sat', name:'Saturday — Optional Long Walk', type:'mobility'},
    {id:'w1-sun', name:'Sunday — Full Rest', type:'rest'}
  ]},
  { label:'Week 2 — Build', days:[
    {id:'w2-mon', name:'Monday — Easy Run + Strides', type:'run'},
    {id:'w2-tue', name:'Tuesday — Full Body Strength A', type:'strength'},
    {id:'w2-wed', name:'Wednesday — Mobility + Band Work', type:'mobility'},
    {id:'w2-thu', name:'Thursday — Full Body Strength B', type:'strength'},
    {id:'w2-fri', name:'Friday — Tempo Intervals', type:'combo'},
    {id:'w2-sat', name:'Saturday — Easy Long Run', type:'run'},
    {id:'w2-sun', name:'Sunday — Full Rest', type:'rest'}
  ]},
  { label:'Week 3 — Load', days:[
    {id:'w3-mon', name:'Monday — Moderate Run + Activation', type:'run'},
    {id:'w3-tue', name:'Tuesday — Full Body Strength A (Peak)', type:'strength'},
    {id:'w3-wed', name:'Wednesday — Active Recovery + Band Circuit', type:'mobility'},
    {id:'w3-thu', name:'Thursday — Full Body Strength B (Peak)', type:'strength'},
    {id:'w3-fri', name:'Friday — Extended Tempo Run', type:'combo'},
    {id:'w3-sat', name:'Saturday — Long Easy Run', type:'run'},
    {id:'w3-sun', name:'Sunday — Full Rest (Earned)', type:'rest'}
  ]},
  { label:'Week 4 — Consolidate', days:[
    {id:'w4-mon', name:'Monday — Easy Run + Assessment', type:'run'},
    {id:'w4-tue', name:'Tuesday — Full Body Strength A (Deload)', type:'strength'},
    {id:'w4-wed', name:'Wednesday — Full Mobility Session', type:'mobility'},
    {id:'w4-thu', name:'Thursday — Full Body Strength B (Deload)', type:'strength'},
    {id:'w4-fri', name:'Friday — Moderate Run', type:'combo'},
    {id:'w4-sat', name:'Saturday — Benchmark Run', type:'run'},
    {id:'w4-sun', name:'Sunday — Rest + Plan Ahead', type:'rest'}
  ]}
];

function tagClass(type) {
  return {run:'tag-run',strength:'tag-strength',mobility:'tag-mobility',combo:'tag-combo',rest:'tag-rest'}[type]||'';
}

function renderTracker() {
  var body = document.getElementById('tracker-body');
  var html = '';
  WEEKS.forEach(function(wk) {
    html += '<div class="week-section"><div class="week-section-title">' + wk.label + '</div>';
    wk.days.forEach(function(day) {
      var d = allLogs[day.id];
      var hasData = !!d;
      html += '<div class="log-entry' + (hasData ? ' has-data' : '') + '">' +
        '<div class="log-entry-top"><span class="log-day-name">' + day.name + '</span><span class="log-type-tag ' + tagClass(day.type) + '">' + day.type + '</span></div>' +
        '<div class="log-data">';
      if (hasData) {
        if (d.dist || d.time || d.pace || d.hr) {
          var parts = [];
          if (d.dist) parts.push(d.dist + ' km');
          if (d.time) parts.push(d.time + ' min');
          if (d.pace) parts.push(d.pace + '/km');
          if (d.hr)   parts.push(d.hr + ' bpm');
          html += '<div class="run-summary">' + parts.join(' · ') + '</div>';
        }
        if (d.exercises) {
          Object.keys(d.exercises).forEach(function(ex) {
            var sets = d.exercises[ex].filter(function(s){ return s.reps || s.kg; });
            if (!sets.length) return;
            var ss = sets.map(function(s){
              if (s.reps && s.kg) return s.reps + '×' + s.kg + 'kg';
              if (s.reps) return s.reps + ' reps';
              return '';
            }).filter(Boolean).join(', ');
            html += '<div class="ex-row"><strong>' + ex + ':</strong> ' + ss + '</div>';
          });
        }
        if (d.notes) html += '<div class="notes-text">"' + d.notes + '"</div>';
        if (!d.dist && !d.exercises && !d.notes) html += '<span class="completed-tick">✓ Completed</span>';
        var when = d.savedAt ? new Date(d.savedAt).toLocaleDateString('en-GB',{day:'numeric',month:'short'}) : '';
        html += '<div class="log-entry-footer">' +
          '<span class="log-meta">' + (when ? 'Logged ' + when : '') + '</span>' +
          '<button class="btn-delete" onclick="deleteLog(\'' + day.id + '\')">✕ Remove</button>' +
          '</div>';
      } else {
        html += '<span class="log-empty">Not logged yet</span>';
      }
      html += '</div></div>';
    });
    html += '</div>';
  });
  body.innerHTML = html;
  updateProgress();
}

function deleteLog(id) {
  if (!allLogs[id]) return;
  delete allLogs[id];
  saveAll(allLogs);
  var card = document.getElementById('card-' + id);
  if (card) card.classList.remove('logged');
  renderTracker();
}

function updateProgress() {
  var done = Object.keys(allLogs).length;
  var pct = Math.round((done / 28) * 100);
  var fill = document.getElementById('progress-fill');
  var text = document.getElementById('progress-text');
  if (fill) fill.style.width = pct + '%';
  if (text) text.textContent = done + ' / 28 sessions';
}

// ── Init ─────────────────────────────────────────────────────────
Object.keys(allLogs).forEach(function(id) {
  var card = document.getElementById('card-' + id);
  if (card) card.classList.add('logged');
});
updateProgress();
</script>
</body>
</html>
