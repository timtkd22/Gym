<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>4-Week Reconditioning Plan</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');
  :root {
    --navy:#0d1b2a; --navy-mid:#1a2e45; --navy-light:#243d57;
    --amber:#e8a020; --amber-dim:#b87a12; --amber-glow:rgba(232,160,32,0.12);
    --slate:#8eaac4; --white:#f0f4f8; --white-dim:rgba(240,244,248,0.6);
    --rest:#2e4a3e; --rest-accent:#4caf82;
    --run:#1e3a5a; --run-accent:#5ba4d4;
    --strength:#3a2a1e; --strength-accent:#e8a020;
    --mobility:#2a1e3a; --mobility-accent:#a07ed4;
    --green:#4caf82;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--navy);color:var(--white);font-family:'Space Grotesk',sans-serif;font-size:15px;line-height:1.6;min-height:100vh}

  /* NAV */
  .main-nav{display:flex;max-width:680px;margin:0 auto;padding:20px 20px 0}
  .nav-tab{flex:1;text-align:center;padding:10px 8px;font-size:13px;font-weight:600;cursor:pointer;border-bottom:2px solid var(--navy-light);color:var(--slate);transition:all .2s;user-select:none}
  .nav-tab.active{color:var(--amber);border-bottom-color:var(--amber)}
  .nav-tab:hover:not(.active){color:var(--white)}
  .main-view{display:none}
  .main-view.active{display:block}

  /* HEADER */
  .header{padding:20px 20px 0;max-width:680px;margin:0 auto}
  .eyebrow{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.18em;color:var(--amber);text-transform:uppercase;margin-bottom:8px}
  h1{font-size:clamp(22px,5vw,32px);font-weight:700;line-height:1.15;letter-spacing:-.02em;margin-bottom:10px}
  h1 span{color:var(--amber)}
  .subtitle{color:var(--white-dim);font-size:13.5px;margin-bottom:24px;max-width:520px}
  .stats-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px}
  .stat{background:var(--navy-mid);border:1px solid var(--navy-light);border-radius:8px;padding:10px 14px;flex:1;min-width:120px}
  .stat-val{font-family:'Space Mono',monospace;font-size:16px;font-weight:700;color:var(--amber)}
  .stat-label{font-size:11px;color:var(--slate);margin-top:2px}
  .legend{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px}
  .legend-item{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--slate)}
  .legend-dot{width:8px;height:8px;border-radius:50%}

  /* WEEK TABS */
  .timeline{display:flex;gap:6px;margin-bottom:24px}
  .tl-week{flex:1;border-radius:6px;padding:10px 10px 8px;cursor:pointer;border:1.5px solid transparent;transition:all .2s;background:var(--navy-mid)}
  .tl-week:hover{border-color:var(--amber-dim)}
  .tl-week.active{border-color:var(--amber);background:var(--amber-glow)}
  .tl-num{font-family:'Space Mono',monospace;font-size:9px;color:var(--slate);letter-spacing:.1em}
  .tl-name{font-size:11px;font-weight:600;color:var(--white);margin-top:2px;line-height:1.2}
  .tl-week.active .tl-name{color:var(--amber)}
  .tl-bar{height:3px;border-radius:2px;margin-top:8px;background:var(--navy-light)}
  .tl-week.active .tl-bar{background:var(--amber)}

  /* WEEK PANELS */
  .week-panel{display:none;max-width:680px;margin:0 auto;padding:0 20px 40px}
  .week-panel.active{display:block}
  .week-intro{background:var(--navy-mid);border-left:3px solid var(--amber);border-radius:0 8px 8px 0;padding:14px 16px;margin-bottom:20px;font-size:13.5px;color:var(--white-dim)}
  .week-intro strong{color:var(--white)}

  /* DAY CARDS */
  .day-card{border-radius:10px;margin-bottom:12px;overflow:hidden;border:1px solid var(--navy-light)}
  .day-card.logged{border-color:rgba(76,175,130,0.4)}
  .day-header{display:flex;align-items:center;gap:12px;padding:12px 16px;cursor:pointer;user-select:none}
  .day-card.rest .day-header{background:var(--rest)}
  .day-card.run .day-header{background:var(--run)}
  .day-card.strength .day-header{background:var(--strength)}
  .day-card.mobility .day-header{background:var(--mobility)}
  .day-card.combo .day-header{background:#2a1e1a}
  .day-tag{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.12em;text-transform:uppercase;padding:3px 7px;border-radius:4px;white-space:nowrap;font-weight:700}
  .rest .day-tag{background:var(--rest-accent);color:#0d1b0d}
  .run .day-tag{background:var(--run-accent);color:#0d1b2a}
  .strength .day-tag{background:var(--strength-accent);color:#1a0d00}
  .mobility .day-tag{background:var(--mobility-accent);color:#1a0d2a}
  .combo .day-tag{background:#d47a40;color:#1a0d00}
  .day-name{font-weight:600;font-size:14.5px;flex:1}
  .day-logged-dot{width:8px;height:8px;border-radius:50%;background:var(--green);display:none;flex-shrink:0}
  .day-card.logged .day-logged-dot{display:block}
  .day-chevron{color:var(--slate);font-size:13px;transition:transform .2s}
  .day-card.open .day-chevron{transform:rotate(180deg)}
  .day-body{display:none;padding:16px;background:rgba(13,27,42,0.5);border-top:1px solid var(--navy-light)}
  .day-card.open .day-body{display:block}
  .session-block{margin-bottom:16px}
  .session-block:last-child{margin-bottom:0}
  .session-title{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--amber);text-transform:uppercase;margin-bottom:10px}
  .exercise-list{list-style:none}
  .exercise-list li{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid rgba(142,170,196,0.1);font-size:13.5px}
  .exercise-list li:last-child{border-bottom:none}
  .ex-name{flex:1;color:var(--white);font-weight:500}
  .ex-detail{font-family:'Space Mono',monospace;font-size:11px;color:var(--amber);white-space:nowrap;padding-top:1px}
  .ex-note{font-size:12px;color:var(--slate);margin-top:3px;line-height:1.4;display:block;font-weight:400}
  .note-box{background:rgba(232,160,32,0.08);border:1px solid rgba(232,160,32,0.2);border-radius:7px;padding:12px 14px;font-size:12.5px;color:var(--white-dim);margin-top:14px}
  .note-box strong{color:var(--amber)}
  .rest-content{font-size:13.5px;color:var(--white-dim);line-height:1.7}
  .rest-content ul{margin:8px 0 0 16px;color:var(--slate);font-size:13px}

  /* LOG BUTTON */
  .log-btn{display:flex;align-items:center;gap:8px;margin-top:16px;background:rgba(232,160,32,0.1);border:1px solid rgba(232,160,32,0.3);border-radius:8px;padding:10px 14px;cursor:pointer;width:100%;font-family:'Space Grotesk',sans-serif;font-size:13px;font-weight:600;color:var(--amber);transition:all .2s}
  .log-btn:hover{background:rgba(232,160,32,0.18)}

  /* MODAL */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:100;align-items:flex-end;justify-content:center}
  .modal-overlay.open{display:flex}
  .modal{background:#0f2035;border:1px solid var(--navy-light);border-radius:16px 16px 0 0;padding:24px 20px 40px;width:100%;max-width:680px;max-height:88vh;overflow-y:auto}
  .modal-title{font-size:16px;font-weight:700;margin-bottom:4px}
  .modal-sub{font-size:12px;color:var(--slate);margin-bottom:20px}
  .modal-section{margin-bottom:20px}
  .modal-section-title{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--amber);text-transform:uppercase;margin-bottom:10px}
  .run-fields{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .field{display:flex;flex-direction:column;gap:4px}
  .field label{font-size:11px;color:var(--slate)}
  .strength-exercise{margin-bottom:16px}
  .strength-ex-name{font-size:13px;font-weight:600;color:var(--white);margin-bottom:8px}
  .set-rows{display:flex;flex-direction:column;gap:6px}
  .set-row{display:flex;gap:8px;align-items:center}
  .set-label{font-family:'Space Mono',monospace;font-size:10px;color:var(--slate);width:38px;flex-shrink:0}
  .set-input{flex:1;min-width:0}

  input[type="number"],input[type="text"],textarea{
    background:var(--navy-mid);border:1px solid var(--navy-light);border-radius:7px;
    color:var(--white);font-family:'Space Grotesk',sans-serif;font-size:14px;
    padding:9px 10px;width:100%;outline:none;transition:border-color .2s;
    -webkit-appearance:none;appearance:none
  }
  input[type="number"]:focus,input[type="text"]:focus,textarea:focus{border-color:var(--amber)}
  textarea{resize:vertical;min-height:64px;font-size:13px}

  .modal-actions{display:flex;gap:10px;margin-top:20px}
  .btn-save{flex:1;background:var(--amber);color:#0d1b2a;border:none;border-radius:8px;padding:14px;font-family:'Space Grotesk',sans-serif;font-size:14px;font-weight:700;cursor:pointer}
  .btn-save:hover{background:#f0b030}
  .btn-cancel{background:var(--navy-mid);border:1px solid var(--navy-light);color:var(--slate);border-radius:8px;padding:14px 18px;font-family:'Space Grotesk',sans-serif;font-size:14px;cursor:pointer}
  .btn-cancel:hover{color:var(--white)}

  /* TRACKER */
  #view-tracker{padding:0 0 48px}
  .tracker-header{padding:20px 20px 16px;max-width:680px;margin:0 auto}
  .tracker-header h2{font-size:20px;font-weight:700;margin-bottom:4px}
  .tracker-header p{font-size:13px;color:var(--white-dim)}
  .progress-bar-wrap{max-width:680px;margin:0 auto 24px;padding:0 20px}
  .progress-label{display:flex;justify-content:space-between;font-size:12px;color:var(--slate);margin-bottom:6px}
  .progress-label span:last-child{color:var(--amber);font-family:'Space Mono',monospace}
  .progress-bg{height:6px;background:var(--navy-mid);border-radius:3px}
  .progress-fill{height:6px;background:var(--amber);border-radius:3px;transition:width .4s}
  .week-section{max-width:680px;margin:0 auto 4px;padding:0 20px}
  .week-section-title{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--amber);text-transform:uppercase;margin-bottom:8px;padding-top:16px;border-top:1px solid var(--navy-light)}
  .log-entry{background:var(--navy-mid);border:1px solid var(--navy-light);border-radius:10px;padding:14px 16px;margin-bottom:8px}
  .log-entry.has-data{border-color:rgba(76,175,130,0.4)}
  .log-entry-top{display:flex;align-items:center;gap:10px;margin-bottom:4px}
  .log-day-name{font-weight:600;font-size:13.5px;flex:1}
  .log-type-tag{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border-radius:4px;font-weight:700}
  .tag-run{background:var(--run-accent);color:#0d1b2a}
  .tag-strength{background:var(--strength-accent);color:#1a0d00}
  .tag-mobility{background:var(--mobility-accent);color:#1a0d2a}
  .tag-combo{background:#d47a40;color:#1a0d00}
  .tag-rest{background:var(--rest-accent);color:#0d1b0d}
  .log-data{font-size:12.5px;color:var(--slate);margin-top:4px}
  .run-summary{color:var(--run-accent);font-family:'Space Mono',monospace;font-size:12px;margin-bottom:4px}
  .ex-row{color:var(--white-dim);font-size:12px;margin-bottom:3px}
  .ex-row strong{color:var(--white)}
  .notes-text{color:var(--slate);font-size:12px;margin-top:6px;font-style:italic}
  .log-empty{color:var(--navy-light);font-size:12px;font-style:italic}
  .log-meta{font-size:11px;color:var(--navy-light);margin-top:6px}
  .completed-tick{color:var(--green);font-size:12px}
  .log-entry-footer{display:flex;align-items:center;justify-content:space-between;margin-top:8px}
  .btn-delete{background:none;border:none;color:rgba(142,170,196,0.4);font-size:11px;cursor:pointer;font-family:'Space Grotesk',sans-serif;padding:0;transition:color .15s}
  .btn-delete:hover{color:#e05555}

  /* PRINCIPLES */
  .divider{height:1px;background:var(--navy-light);max-width:680px;margin:8px auto 20px}
  .principles{max-width:680px;margin:0 auto;padding:0 20px 48px}
  .principles-title{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.18em;color:var(--amber);text-transform:uppercase;margin-bottom:12px}
  .principles-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .principle{background:var(--navy-mid);border:1px solid var(--navy-light);border-radius:8px;padding:12px 14px;font-size:12.5px;color:var(--white-dim)}
  .principle strong{color:var(--white);display:block;margin-bottom:2px}
</style>
</head>
<body>

<div class="main-nav">
  <div class="nav-tab active" data-view="plan">📋 Plan</div>
  <div class="nav-tab" data-view="tracker">📊 My Sessions</div>
</div>

<!-- ==================== PLAN VIEW ==================== -->
<div class="main-view active" id="view-plan">
<div class="header">
  <div class="eyebrow">Personal Training Plan · June 2026</div>
  <h1>4-Week <span>Reconditioning</span><br>Foundation Plan</h1>
  <p class="subtitle">Built around your 10k base, 5km daily commute walk, and home kit. Goal: rebuild movement quality, aerobic efficiency, and structural strength before stepping up intensity.</p>
  <div class="stats-row">
    <div class="stat"><div class="stat-val">53:48</div><div class="stat-label">Recent 10k time</div></div>
    <div class="stat"><div class="stat-val">5km</div><div class="stat-label">Daily walk (commute)</div></div>
    <div class="stat"><div class="stat-val">4 wks</div><div class="stat-label">Programme length</div></div>
    <div class="stat"><div class="stat-val">~5–6h</div><div class="stat-label">Weekly training time</div></div>
  </div>
  <div class="legend">
    <div class="legend-item"><div class="legend-dot" style="background:#4caf82"></div>Rest</div>
    <div class="legend-item"><div class="legend-dot" style="background:#5ba4d4"></div>Run</div>
    <div class="legend-item"><div class="legend-dot" style="background:#e8a020"></div>Strength</div>
    <div class="legend-item"><div class="legend-dot" style="background:#a07ed4"></div>Mobility</div>
    <div class="legend-item"><div class="legend-dot" style="background:#d47a40"></div>Combo</div>
    <div class="legend-item"><div class="legend-dot" style="background:#4caf82"></div>✓ Logged</div>
  </div>
  <div class="timeline">
    <div class="tl-week active" data-week="1"><div class="tl-num">WK 01</div><div class="tl-name">Reawaken</div><div class="tl-bar"></div></div>
    <div class="tl-week" data-week="2"><div class="tl-num">WK 02</div><div class="tl-name">Build</div><div class="tl-bar"></div></div>
    <div class="tl-week" data-week="3"><div class="tl-num">WK 03</div><div class="tl-name">Load</div><div class="tl-bar"></div></div>
    <div class="tl-week" data-week="4"><div class="tl-num">WK 04</div><div class="tl-name">Consolidate</div><div class="tl-bar"></div></div>
  </div>
</div>

<!-- WEEK 1 -->
<div class="week-panel active" id="week-1">
  <div class="week-intro"><strong>Week 1 — Reawaken.</strong> Effort is deliberately low. Runs at easy conversational pace. Weights light — focus on form and range of motion. Every session should end feeling like you could have done more.</div>

  <div class="day-card run open" id="card-w1-mon">
    <div class="day-header" onclick="toggleDay(this)"><span class="day-tag">Run</span><span class="day-name">Monday — Easy Run + Activation</span><span class="day-logged-dot"></span><span class="day-chevron">▾</span></div>
    <div class="day-body">
      <div class="session-block"><div class="session-title">Main Run · 25 min easy</div>
        <ul class="exercise-list">
          <li><span class="ex-name">Easy continuous run<span class="ex-note">Conversational pace. Expect ~6:30–7:00/km.</span></span><span class="ex-detail">25 min</span></li>
        </ul>
      </div>
      <div class="session-block"><div class="session-title">Activation Circuit · 2 rounds</div>
        <ul class="exercise-list">
          <li><span class="ex-name">Glute bridges<span class="ex-note">Pause 1 sec at top</span></span><span class="ex-detail">12 reps</span></li>
          <li><span class="ex-name">Banded clamshells</span><span class="ex-detail">12 each</span></li>
          <li><span class="ex-name">Dead bugs<span class="ex-note">Lower back pressed to floor</span></span><span class="ex-detail">8 each side</span></li>
          <li><span class="ex-name">Band pull-aparts</span><span class="ex-detail">15 reps</span></li>
        </ul>
      </div>
      <button class="log-btn" onclick="openLog('w1-mon','W1 Mon — Easy Run + Activation','run',['run'])">＋ Log this session</button>
    </div>
  </div>

  <div class="day-card strength" id="card-w1-tue">
    <div class="day-header" onclick="toggleDay(this)"><span class="day-tag">Strength</span><span class="day-name">Tuesday — Full Body Strength A</span><span class="day-logged-dot"></span><span class="day-chevron">▾</span></div>
    <div class="day-body">
      <div class="session-block"><div class="session-title">Main Work · 3 sets, 90 sec rest</div>
        <ul class="exercise-list">
          <li><span class="ex-name">Goblet squat<span class="ex-note">Full depth, chest up</span></span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Dumbbell bench press<span class="ex-note">3 sec lowering</span></span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Romanian deadlift<span class="ex-note">Hip hinge, back flat</span></span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Single-arm row (each side)<span class="ex-note">Elbow drives back</span></span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Lateral raises<span class="ex-note">Very light, lead with elbows</span></span><span class="ex-detail">3×12</span></li>
        </ul>
      </div>
      <div class="session-block"><div class="session-title">Core Finisher</div>
        <ul class="exercise-list">
          <li><span class="ex-name">Plank holds</span><span class="ex-detail">3×20 sec</span></li>
          <li><span class="ex-name">Birddog</span><span class="ex-detail">2×8 each</span></li>
        </ul>
      </div>
      <div class="note-box"><strong>Weight:</strong> Last 2 reps at 6/10 effort. This week is about groove, not load.</div>
      <button class="log-btn" onclick="openLog('w1-tue','W1 Tue — Full Body Strength A','strength',['Goblet Squat','Bench Press','Romanian Deadlift','Single-arm Row','Lateral Raises','Plank','Birddog'])">＋ Log this session</button>
    </div>
  </div>

  <div class="day-card mobility" id="card-w1-wed">
    <div class="day-header" onclick="toggleDay(this)"><span class="day-tag">Mobility</span><span class="day-name">Wednesday — Active Recovery + Mobility</span><span class="day-logged-dot"></span><span class="day-chevron">▾</span></div>
    <div class="day-body">
      <div class="rest-content"><p>No structured training. Address tightness from desk work and Mon/Tue.</p>
        <ul><li>Hip flexor stretch — 60 sec each side</li><li>Thoracic rotation — 10 each side</li><li>World's greatest stretch — 5 each side</li><li>Hamstring stretch with band — 60 sec each side</li><li>Neck and shoulder rolls — 2 min</li></ul>
      </div>
      <div class="note-box"><strong>Priority:</strong> Hip flexors and thoracic spine — these limit both running and lifting if left tight.</div>
      <button class="log-btn" onclick="openLog('w1-wed','W1 Wed — Active Recovery + Mobility','rest',[])">＋ Mark as done</button>
    </div>
  </div>

  <div class="day-card strength" id="card-w1-thu">
    <div class="day-header" onclick="toggleDay(this)"><span class="day-tag">Strength</span><span class="day-name">Thursday — Full Body Strength B</span><span class="day-logged-dot"></span><span class="day-chevron">▾</span></div>
    <div class="day-body">
      <div class="session-block"><div class="session-title">Main Work · 3 sets, 90 sec rest</div>
        <ul class="exercise-list">
          <li><span class="ex-name">Reverse lunge<span class="ex-note">Both legs, front knee tracks over toe</span></span><span class="ex-detail">3×8 each</span></li>
          <li><span class="ex-name">Floor press<span class="ex-note">Use bench if available</span></span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Sumo deadlift<span class="ex-note">Wide stance, toes out</span></span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Banded face pulls<span class="ex-note">Key for desk posture</span></span><span class="ex-detail">3×15</span></li>
          <li><span class="ex-name">Curl to press (combo)</span><span class="ex-detail">3×10</span></li>
        </ul>
      </div>
      <div class="session-block"><div class="session-title">Core Finisher</div>
        <ul class="exercise-list">
          <li><span class="ex-name">Lying leg raises</span><span class="ex-detail">3×10</span></li>
          <li><span class="ex-name">Side plank each side</span><span class="ex-detail">2×20 sec</span></li>
        </ul>
      </div>
      <button class="log-btn" onclick="openLog('w1-thu','W1 Thu — Full Body Strength B','strength',['Reverse Lunge','Floor Press','Sumo Deadlift','Banded Face Pulls','Curl to Press','Leg Raises','Side Plank'])">＋ Log this session</button>
    </div>
  </div>

  <div class="day-card run" id="card-w1-fri">
    <div class="day-header" onclick="toggleDay(this)"><span class="day-tag">Run</span><span class="day-name">Friday — Easy Run</span><span class="day-logged-dot"></span><span class="day-chevron">▾</span></div>
    <div class="day-body">
